## ==========================================
## Visual Studio / C# / WinForms / .NET
## GitIgnore recomendado completo
## ==========================================

# -------------------------
# Build
# -------------------------
[Bb]in/
[Oo]bj/
x64/
x86/
[Dd]ebug/
[Rr]elease/

# -------------------------
# Visual Studio
# -------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# -------------------------
# Rider / Resharper
# -------------------------
_ReSharper*/
*.DotSettings.user

# -------------------------
# Cache / temporales
# -------------------------
*.cache
*.tmp
*.temp
*.log
*.bak
*.old

# -------------------------
# Windows
# -------------------------
Thumbs.db
Desktop.ini

# -------------------------
# VS Code
# -------------------------
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# -------------------------
# Nuget
# -------------------------
packages/
*.nupkg

# -------------------------
# Test / coverage
# -------------------------
TestResults/
coverage/
*.coverage
*.coveragexml

# -------------------------
# Publicaciones
# -------------------------
publish/
Publish/

# -------------------------
# SQL / LocalDB
# -------------------------
*.mdf
*.ldf

# -------------------------
# Logs varios
# -------------------------
*.tlog
*.pidb
*.svclog

# -------------------------
# Node (si usás frontend)
# -------------------------
node_modules/

# -------------------------
# Archivos comprimidos
# -------------------------
*.zip
*.rar
*.7z

# -------------------------
# Multimedia pesados
# -------------------------
*.mp4
*.avi
*.mov

# -------------------------
# SOLO JSON basura de Visual Studio
# -------------------------
.vs/**/*.json

# -------------------------
# NO ignorar código fuente
# -------------------------
!*.cs
!*.csproj
!*.sln
!*.config
!*.json